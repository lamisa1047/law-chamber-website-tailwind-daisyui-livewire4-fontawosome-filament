{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "start": "php artisan serve --port=8000",
        "watch": "concurrently \"npm run dev\" \"npm run start\"",
        "php": "php artisan",
        "log": "tail -f storage/logs/laravel.log",
        "clear": "php artisan config:clear && php artisan route:clear && php artisan cache:clear"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "concurrently": "^9.0.1",
        "daisyui": "^5.5.19",
        "laravel-vite-plugin": "^3.0.0",
        "tailwindcss": "^4.0.0",
        "vite": "^8.0.0"
    }
}
